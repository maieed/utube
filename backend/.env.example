PORT=4000
ALLOWED_ORIGINS=http://localhost:5173

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Telegram group/channel chat id (usually starts with -100...)
TELEGRAM_CHAT_ID=

# Sync interval for polling Telegram updates
SYNC_INTERVAL_MS=45000

# Optional custom path for catalog persistence
CATALOG_PATH=./data/video-catalog.json
